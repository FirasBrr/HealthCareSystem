{% extends 'base.html.twig' %}

{% block title %}MedicalApp - My Appointments{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #2c7be5;
            --primary-light: #e3ebf8;
            --primary-dark: #1a68d1;
            --secondary: #6e84a3;
            --success: #00d97e;
            --success-light: #e6f9f0;
            --warning: #f6c343;
            --warning-light: #fef8e6;
            --danger: #e63757;
            --danger-light: #fce9ec;
            --info: #39afd1;
            --info-light: #eaf5f9;
            --light: #f9fbfd;
            --dark: #12263f;
            --gray-100: #f8f9fa;
            --gray-200: #e9ecef;
            --gray-300: #dee2e6;
            --gray-400: #ced4da;
            --gray-500: #adb5bd;
            --gray-600: #6c757d;
            --gray-700: #495057;
            --gray-800: #343a40;
            --gray-900: #212529;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --body-bg: #f5f7fb;
            --gradient-primary: linear-gradient(135deg, #2c7be5 0%, #1a68d1 100%);
            --gradient-success: linear-gradient(135deg, #00d97e 0%, #00b86c 100%);
            --gradient-warning: linear-gradient(135deg, #f6c343 0%, #f4b223 100%);
            --gradient-danger: linear-gradient(135deg, #e63757 0%, #d92545 100%);
            --shadow-sm: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            --shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            --shadow-lg: 0 1rem 3rem rgba(0, 0, 0, 0.175);
            --border-radius: 0.75rem;
            --border-radius-sm: 0.5rem;
            --transition: all 0.3s ease;
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .dashboard-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--gray-200);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .patient-avatar-large {
            width: 50px;
            height: 50px;
            background: var(--gradient-primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.25rem;
            font-weight: 600;
        }

        .patient-info h6 {
            margin-bottom: 0.25rem;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .patient-info small {
            color: var(--gray-600);
            font-size: 0.8rem;
        }

        .sidebar-nav {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        .nav-section {
            margin-bottom: 2rem;
        }

        .nav-section-title {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--gray-600);
            letter-spacing: 0.5px;
            margin-bottom: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 0.7rem 1rem;
            border-radius: var(--border-radius-sm);
            color: var(--gray-700);
            text-decoration: none;
            margin-bottom: 0.5rem;
            transition: var(--transition);
            font-weight: 500;
            font-size: 0.9rem;
        }

        .nav-item:hover {
            background: var(--primary-light);
            color: var(--primary);
            transform: translateX(5px);
        }

        .nav-item.active {
            background: var(--gradient-primary);
            color: white;
            box-shadow: 0 4px 12px rgba(44, 123, 229, 0.3);
        }

        .nav-icon {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            background: var(--gray-100);
            color: var(--gray-600);
            transition: var(--transition);
        }

        .nav-item:hover .nav-icon {
            background: white;
        }

        .nav-item.active .nav-icon {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--gray-200);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            padding: 0.7rem 1rem;
            border-radius: var(--border-radius-sm);
            color: var(--danger);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: var(--transition);
        }

        .logout-btn:hover {
            background: var(--danger-light);
        }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 1.5rem;
            max-width: calc(100% - 280px);
        }

        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--gray-200);
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-left h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.25rem;
        }

        .header-left p {
            color: var(--gray-600);
            margin: 0;
            font-size: 0.85rem;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .date-badge {
            background: var(--primary-light);
            color: var(--primary);
            padding: 0.4rem 0.8rem;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.8rem;
        }

        /* Page Header */
        .page-header {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1.25rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
        }

        .page-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
        }

        .page-subtitle {
            color: var(--gray-600);
            margin: 0.3rem 0 0 0;
            font-size: 0.85rem;
        }

        /* Stats Summary */
        .stats-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .stat-summary-item {
            background: var(--card-bg);
            border-radius: var(--border-radius-sm);
            padding: 0.8rem;
            text-align: center;
            border: 1px solid var(--gray-200);
            transition: var(--transition);
            cursor: pointer;
        }

        .stat-summary-count {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
            display: block;
        }

        .stat-summary-label {
            font-size: 0.7rem;
            color: var(--gray-600);
        }

        /* Filter Section */
        .filter-section {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1.25rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
        }

        .filter-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .filter-header h4 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--dark);
            margin: 0;
        }

        .filter-reset {
            padding: 0.4rem 0.8rem;
            background: var(--gray-100);
            color: var(--gray-700);
            border: none;
            border-radius: var(--border-radius-sm);
            font-size: 0.75rem;
            font-weight: 500;
            cursor: pointer;
        }

        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
        }

        .filter-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 0.3rem;
        }

        .filter-select {
            width: 100%;
            padding: 0.6rem;
            border: 1px solid var(--gray-300);
            border-radius: var(--border-radius-sm);
            font-size: 0.85rem;
        }

        /* Appointments List */
        .appointments-section {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1.25rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
        }

        .appointment-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .appointment-item {
            display: flex;
            align-items: center;
            padding: 0.8rem;
            background: var(--gray-100);
            border-radius: var(--border-radius-sm);
            transition: var(--transition);
            border-left: 4px solid transparent;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .appointment-item.pending { border-left-color: var(--warning); }
        .appointment-item.confirmed { border-left-color: var(--success); }
        .appointment-item.cancelled { border-left-color: var(--danger); }
        .appointment-item.completed { border-left-color: var(--secondary); }

        .appointment-time {
            min-width: 100px;
            text-align: center;
            padding: 0.5rem;
            background: white;
            border-radius: 8px;
        }

        .appointment-time .time {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--dark);
            display: block;
        }

        .appointment-time .date {
            font-size: 0.7rem;
            color: var(--gray-600);
        }

        .doctor-info {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            min-width: 150px;
        }

        .doctor-avatar-small {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            background: var(--gradient-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .doctor-details h6 {
            font-weight: 600;
            margin-bottom: 0.2rem;
            color: var(--dark);
            font-size: 0.85rem;
        }

        .doctor-details p {
            color: var(--gray-600);
            font-size: 0.7rem;
            margin: 0;
        }

        .appointment-status {
            padding: 0.2rem 0.6rem;
            border-radius: 50px;
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-pending {
            background: var(--warning-light);
            color: var(--warning);
        }

        .status-confirmed {
            background: var(--success-light);
            color: var(--success);
        }

        .status-cancelled {
            background: var(--danger-light);
            color: var(--danger);
        }

        .status-completed {
            background: var(--gray-200);
            color: var(--gray-700);
        }

        .appointment-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn-action {
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            border: none;
            font-size: 0.75rem;
            font-weight: 500;
            cursor: pointer;
        }

        .btn-cancel {
            background: var(--danger-light);
            color: var(--danger);
        }

        .btn-disabled {
            background: var(--gray-300);
            color: var(--gray-600);
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            font-size: 0.75rem;
            cursor: not-allowed;
        }

        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--gray-600);
        }

        .empty-state i {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
            color: var(--gray-400);
        }

        .empty-state h5 {
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            font-size: 0.85rem;
        }

        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                margin-bottom: 1rem;
            }
            .main-content {
                margin-left: 0;
                max-width: 100%;
                padding: 1rem;
            }
        }

        @media (max-width: 768px) {
            .top-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .header-right {
                width: 100%;
                justify-content: space-between;
            }
            .stats-summary {
                grid-template-columns: repeat(2, 1fr);
            }
            .appointment-item {
                flex-direction: column;
                align-items: stretch;
            }
            .appointment-time {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .doctor-info {
                width: 100%;
            }
            .appointment-actions {
                width: 100%;
            }
            .btn-action {
                flex: 1;
                text-align: center;
            }
        }

        @media (max-width: 480px) {
            .stats-summary {
                grid-template-columns: 1fr;
            }
            .filter-grid {
                grid-template-columns: 1fr;
            }
            .header-left h1 {
                font-size: 1.2rem;
            }
            .page-title {
                font-size: 1.1rem;
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="patient-avatar-large">
                    {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                </div>
                <div class="patient-info">
                    <h6>{{ app.user.firstName }} {{ app.user.lastName }}</h6>
                    <small>Patient</small>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a href="{{ path('app_dashboard') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-home"></i></div>
                        Dashboard
                    </a>
                    <a href="{{ path('patient_appointments') }}" class="nav-item active">
                        <div class="nav-icon"><i class="fas fa-calendar-alt"></i></div>
                        Appointments
                    </a>
                    <a href="{{ path('patient_prescriptions') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-file-prescription"></i></div>
                        Prescriptions
                    </a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Health</div>
                    <a href="{{ path('patient_doctors') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-search"></i></div>
                        Find Doctors
                    </a>
                </div>
            </nav>
            <div class="sidebar-footer">
                <a href="{{ path('app_logout') }}" class="logout-btn">
                    <i class="fas fa-sign-out-alt me-2"></i> Logout
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-header">
                <div class="header-left">
                    <h1>Welcome, {{ app.user.firstName }}</h1>
                    <p>Manage all your medical appointments</p>
                </div>
                <div class="header-right">
                    <div class="date-badge">
                        <i class="fas fa-calendar-day me-2"></i>{{ "now"|date("M j, Y") }}
                    </div>
                </div>
            </div>

            <div class="page-header">
                <h1 class="page-title">My Appointments</h1>
                <p class="page-subtitle">View and manage your scheduled appointments</p>
            </div>

            <div class="stats-summary">
                <div class="stat-summary-item" onclick="setStatusFilter('all')">
                    <span class="stat-summary-count">{{ appointments|length }}</span>
                    <span class="stat-summary-label">Total</span>
                </div>
                <div class="stat-summary-item" onclick="setStatusFilter('pending')">
                    <span class="stat-summary-count">{{ appointments|filter(a => a.status == 'Pending')|length }}</span>
                    <span class="stat-summary-label">Pending</span>
                </div>
                <div class="stat-summary-item" onclick="setStatusFilter('confirmed')">
                    <span class="stat-summary-count">{{ appointments|filter(a => a.status == 'Confirmed')|length }}</span>
                    <span class="stat-summary-label">Confirmed</span>
                </div>
                <div class="stat-summary-item" onclick="setStatusFilter('cancelled')">
                    <span class="stat-summary-count">{{ appointments|filter(a => a.status == 'Cancelled')|length }}</span>
                    <span class="stat-summary-label">Cancelled</span>
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-header">
                    <h4><i class="fas fa-filter me-2 text-primary"></i>Filter Appointments</h4>
                    <button class="filter-reset" onclick="resetFilters()"><i class="fas fa-redo me-1"></i>Reset</button>
                </div>
                <div class="filter-grid">
                    <div>
                        <label class="filter-label">Status</label>
                        <select id="statusFilter" class="filter-select" onchange="filterAppointments()">
                            <option value="all">All Status</option>
                            <option value="pending">Pending</option>
                            <option value="confirmed">Confirmed</option>
                            <option value="cancelled">Cancelled</option>
                        </select>
                    </div>
                    <div>
                        <label class="filter-label">Time Period</label>
                        <select id="timeFilter" class="filter-select" onchange="filterAppointments()">
                            <option value="all">All Time</option>
                            <option value="upcoming">Upcoming</option>
                            <option value="past">Past</option>
                            <option value="today">Today</option>
                        </select>
                    </div>
                    <div>
                        <label class="filter-label">Sort By</label>
                        <select id="sortFilter" class="filter-select" onchange="filterAppointments()">
                            <option value="date_desc">Newest First</option>
                            <option value="date_asc">Oldest First</option>
                            <option value="status">Status</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="appointments-section">
                <div id="appointmentsContainer">
                    {% if appointments|length > 0 %}
                        <div class="appointment-list">
                            {% for appointment in appointments %}
                                <div class="appointment-item {{ appointment.status|lower }}"
                                     data-status="{{ appointment.status|lower }}"
                                     data-date="{{ appointment.startDateTime|date('Y-m-d') }}"
                                     data-time="{{ appointment.startDateTime|date('H:i:s') }}">
                                    <div class="appointment-time">
                                        <span class="time">{{ appointment.startDateTime|date('h:i A') }}</span>
                                        <span class="date">{{ appointment.startDateTime|date('M j, Y') }}</span>
                                    </div>
                                    <div class="doctor-info">
                                        <div class="doctor-avatar-small">
                                            {{ appointment.doctor.client.firstName|first|upper }}{{ appointment.doctor.client.lastName|first|upper }}
                                        </div>
                                        <div class="doctor-details">
                                            <h6>Dr. {{ appointment.doctor.client.firstName }} {{ appointment.doctor.client.lastName }}</h6>
                                            <p><i class="fas fa-stethoscope me-1"></i>{{ appointment.doctor.specialty ?? 'General Medicine' }}</p>
                                        </div>
                                    </div>
                                    <span class="appointment-status status-{{ appointment.status|lower }}">{{ appointment.status }}</span>
                                    <div class="appointment-actions">
                                        {% if appointment.status == 'Pending' or appointment.status == 'Confirmed' %}
                                            <button class="btn-action btn-cancel" onclick="cancelAppointment({{ appointment.id }})">Cancel</button>
                                        {% elseif appointment.status == 'Completed' %}
                                            <span class="btn-disabled">Completed</span>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            <i class="fas fa-calendar-plus"></i>
                            <h5>No appointments found</h5>
                            <p>You haven't booked any appointments yet.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </main>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        let allAppointments = [];

        document.addEventListener('DOMContentLoaded', function() {
            const items = document.querySelectorAll('.appointment-item');
            allAppointments = Array.from(items).map(item => ({
                element: item.cloneNode(true),
                status: item.dataset.status,
                date: item.dataset.date,
                time: item.dataset.time,
                timestamp: new Date(item.dataset.date + ' ' + item.dataset.time).getTime()
            }));
        });

        function filterAppointments() {
            const statusFilter = document.getElementById('statusFilter').value;
            const timeFilter = document.getElementById('timeFilter').value;
            const sortFilter = document.getElementById('sortFilter').value;

            let filtered = allAppointments.filter(a => {
                if (statusFilter !== 'all' && a.status !== statusFilter) return false;
                const now = new Date();
                const aptDate = new Date(a.timestamp);
                if (timeFilter === 'upcoming' && aptDate < now) return false;
                if (timeFilter === 'past' && aptDate >= now) return false;
                if (timeFilter === 'today' && aptDate.toDateString() !== now.toDateString()) return false;
                return true;
            });

            filtered.sort((a, b) => {
                if (sortFilter === 'date_asc') return a.timestamp - b.timestamp;
                if (sortFilter === 'date_desc') return b.timestamp - a.timestamp;
                if (sortFilter === 'status') return a.status.localeCompare(b.status);
                return b.timestamp - a.timestamp;
            });

            const container = document.getElementById('appointmentsContainer');
            if (filtered.length > 0) {
                const list = document.createElement('div');
                list.className = 'appointment-list';
                filtered.forEach(a => list.appendChild(a.element.cloneNode(true)));
                container.innerHTML = '';
                container.appendChild(list);
            } else {
                container.innerHTML = `<div class="empty-state"><i class="fas fa-calendar-times"></i><h5>No appointments found</h5><p>Try adjusting your filters.</p></div>`;
            }
        }

        function resetFilters() {
            document.getElementById('statusFilter').value = 'all';
            document.getElementById('timeFilter').value = 'all';
            document.getElementById('sortFilter').value = 'date_desc';
            filterAppointments();
        }

        function setStatusFilter(status) {
            document.getElementById('statusFilter').value = status;
            filterAppointments();
        }

        function cancelAppointment(id) {
            if (confirm('Cancel this appointment?')) {
                fetch('/patient/appointment/' + id + '/cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
                }).then(r => r.json()).then(data => {
                    if (data.success) location.reload();
                    else alert('Error: ' + data.message);
                }).catch(() => alert('Error cancelling'));
            }
        }
    </script>
{% endblock %}