<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>{% block title %}MedicalApp{% endblock %}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚕️</text></svg>">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* Desktop Only Message Styles */
        #desktopOnlyMessage {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: white;
            z-index: 99999;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        }

        .message-container {
            text-align: center;
            padding: 40px 20px;
            max-width: 400px;
            margin: 0 auto;
            margin-top: 25vh;
        }

        .desktop-icon {
            font-size: 80px;
            margin-bottom: 20px;
            color: #2c7be5;
        }

        .message-title {
            font-size: 28px;
            margin-bottom: 15px;
            color: #12263f;
            font-weight: 700;
        }

        .message-text {
            font-size: 16px;
            color: #6e84a3;
            line-height: 1.5;
            margin-bottom: 25px;
        }

        .info-box {
            background: #f8f9fa;
            border-radius: 16px;
            padding: 20px;
            margin-top: 20px;
        }

        .info-box p {
            margin: 0;
            color: #6e84a3;
            font-size: 14px;
        }

        .info-box i {
            margin-right: 8px;
            color: #2c7be5;
        }

        .screen-width-info {
            font-size: 12px;
            color: #cbd5e1;
            margin-top: 30px;
        }

        #mainAppContent {
            display: block;
        }
    </style>

    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% endblock %}
</head>
<body>

<!-- Desktop Only Message -->
<div id="desktopOnlyMessage">
    <div class="message-container">
        <div class="desktop-icon">
            <i class="fas fa-desktop"></i>
        </div>
        <h1 class="message-title">Desktop Only</h1>
        <p class="message-text">
            This application is designed for desktop computers only.<br><br>
            Please access MedicalApp from a laptop or desktop computer.
        </p>
        <div class="info-box">
            <p>
                <i class="fas fa-laptop"></i>
                Use laptop or desktop computer
            </p>
        </div>
        <div class="screen-width-info">
            Screen width: <span id="screenWidth"></span>px<br>
            (Minimum required: 1025px)
        </div>
    </div>
</div>

<!-- Main App Content -->
<div id="mainAppContent">
    <main>
        {% block body %}{% endblock %}
    </main>
</div>

<script>
    function checkDesktopOnly() {
        // Desktop requires screen width greater than 1024px
        const isDesktop = window.innerWidth >= 1025;
        const messageDiv = document.getElementById('desktopOnlyMessage');
        const contentDiv = document.getElementById('mainAppContent');
        const screenWidthSpan = document.getElementById('screenWidth');

        if (screenWidthSpan) {
            screenWidthSpan.textContent = window.innerWidth;
        }

        if (!isDesktop) {
            // Mobile/Tablet - show message, hide content
            messageDiv.style.display = 'block';
            contentDiv.style.display = 'none';
            document.body.style.overflow = 'hidden';
        } else {
            // Desktop - hide message, show content
            messageDiv.style.display = 'none';
            contentDiv.style.display = 'block';
            document.body.style.overflow = 'auto';
        }
    }

    // Check on load
    checkDesktopOnly();

    // Check on resize
    window.addEventListener('resize', checkDesktopOnly);

    // Check on orientation change
    window.addEventListener('orientationchange', function() {
        setTimeout(checkDesktopOnly, 100);
    });
</script>

</body>
</html>