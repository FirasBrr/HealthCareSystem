{% extends 'base.html.twig' %}

{% block title %}MedicalApp - Create Your Account{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #2c7be5;
            --primary-dark: #1a68d1;
            --secondary: #6e84a3;
            --success: #00d97e;
            --light: #f9fbfd;
            --dark: #12263f;
            --gradient: linear-gradient(135deg, #2c7be5 0%, #6e84a3 100%);
        }

        .register-section {
            background: var(--gradient);
            color: white;
            padding: 60px 0;
            position: relative;
            overflow: hidden;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .register-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" opacity="0.1"><path fill="white" d="M500,250c138,0,250,112,250,250S638,750,500,750S250,638,250,500S362,250,500,250z"/></svg>') repeat;
            background-size: 150px;
        }

        .register-card {
            background: white;
            border-radius: 20px;
            padding: 30px 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
            position: relative;
            z-index: 2;
        }

        .register-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.5rem;
            text-align: center;
        }

        .register-subtitle {
            color: var(--secondary);
            text-align: center;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }

        .form-group-custom {
            margin-bottom: 1.2rem;
        }

        .form-label-custom {
            color: var(--dark);
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .form-control-custom {
            border: 2px solid #e3ebf6;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: #f9fbfd;
            width: 100%;
        }

        .form-control-custom:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(44, 123, 229, 0.1);
            background: white;
            outline: none;
        }

        /* Radio Group - Mobile Friendly */
        .radio-group {
            display: flex;
            gap: 12px;
            margin-top: 10px;
            flex-direction: column;
        }

        .radio-option {
            position: relative;
            width: 100%;
        }

        .radio-input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }

        .radio-label {
            display: flex;
            align-items: center;
            padding: 15px;
            background: var(--light);
            border: 2px solid #e3ebf6;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
            color: var(--dark);
            width: 100%;
        }

        .radio-label:hover {
            border-color: var(--primary);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 123, 229, 0.1);
        }

        .radio-input:checked + .radio-label {
            border-color: var(--primary);
            background: rgba(44, 123, 229, 0.05);
            box-shadow: 0 5px 15px rgba(44, 123, 229, 0.1);
        }

        .radio-icon {
            width: 20px;
            height: 20px;
            border: 2px solid #6e84a3;
            border-radius: 50%;
            margin-right: 12px;
            position: relative;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .radio-input:checked + .radio-label .radio-icon {
            border-color: var(--primary);
            background: var(--primary);
        }

        .radio-input:checked + .radio-label .radio-icon::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 8px;
            height: 8px;
            background: white;
            border-radius: 50%;
        }

        .role-icon {
            margin-right: 8px;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .btn-register {
            background: var(--primary);
            color: white !important;
            border: none;
            padding: 12px 24px;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 12px;
            width: 100%;
            transition: all 0.3s ease;
            margin-top: 1rem;
        }

        .btn-register:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(44, 123, 229, 0.3);
            color: white !important;
        }

        .login-link {
            text-align: center;
            margin-top: 1.5rem;
            color: var(--secondary);
            font-size: 0.9rem;
        }

        .login-link a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .login-link a:hover {
            text-decoration: underline;
        }

        .feature-icon-small {
            width: 50px;
            height: 50px;
            background: var(--gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
            margin-bottom: 1rem;
        }

        .benefits-list {
            list-style: none;
            padding: 0;
        }

        .benefits-list li {
            padding: 0.4rem 0;
            color: var(--secondary);
            font-size: 0.85rem;
        }

        .benefits-list li i {
            color: var(--success);
            margin-right: 0.5rem;
            width: 20px;
        }

        .role-description {
            background: var(--light);
            border-radius: 12px;
            padding: 12px;
            margin-top: 10px;
            border-left: 4px solid var(--primary);
        }

        .role-description h6 {
            color: var(--dark);
            margin-bottom: 5px;
            font-size: 0.9rem;
        }

        .role-description p {
            color: var(--secondary);
            margin-bottom: 0;
            font-size: 0.8rem;
        }

        .dynamic-fields-container {
            background: var(--light);
            border-radius: 12px;
            padding: 15px;
            margin-top: 10px;
            border: 2px dashed var(--primary);
            transition: all 0.3s ease;
            display: none;
        }

        .dynamic-fields-container.active {
            display: block;
        }

        .dynamic-fields-container h6 {
            color: var(--primary);
            margin-bottom: 12px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .form-error {
            color: #dc3545;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }

        .form-error ul {
            list-style: none;
            padding-left: 0;
            margin-bottom: 0;
        }

        small.text-muted {
            font-size: 0.7rem;
        }

        /* Password strength */
        .password-strength {
            margin-top: 0.5rem;
        }

        .progress {
            height: 4px;
            margin-bottom: 0.25rem;
        }

        /* ============================================ */
        /* RESPONSIVE STYLES */
        /* ============================================ */

        /* Tablet and up */
        @media (min-width: 768px) {
            .register-section {
                padding: 80px 0;
            }
            
            .register-card {
                padding: 50px 40px;
            }
            
            .register-title {
                font-size: 2rem;
            }
            
            .register-subtitle {
                font-size: 1rem;
            }
            
            .radio-group {
                flex-direction: row;
            }
            
            .radio-group {
                flex-direction: row;
                gap: 15px;
            }
            
            .radio-label {
                padding: 20px;
            }
        }

        /* Desktop */
        @media (min-width: 992px) {
            .register-title {
                font-size: 2.5rem;
            }
            
            .register-subtitle {
                font-size: 1.1rem;
            }
            
            .register-card {
                padding: 50px 40px;
            }
        }

        /* Small mobile */
        @media (max-width: 480px) {
            .register-section {
                padding: 40px 0;
            }
            
            .register-card {
                padding: 20px 15px;
            }
            
            .register-title {
                font-size: 1.5rem;
            }
            
            .form-label-custom {
                font-size: 0.85rem;
            }
            
            .form-control-custom {
                padding: 8px 12px;
                font-size: 0.9rem;
            }
            
            .btn-register {
                padding: 10px 20px;
                font-size: 0.9rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <!-- Register Section -->
    <section class="register-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-10">
                    <div class="register-card">
                        <div class="row">
                            <!-- Registration Form -->
                            <div class="col-12 col-lg-6">
                                <h1 class="register-title">Create Your Account</h1>
                                <p class="register-subtitle">Join thousands managing their health with MedicalApp</p>

                                {{ form_start(registrationForm) }}
                                
                                <div class="row">
                                    <div class="col-12 col-md-6">
                                        <div class="form-group-custom">
                                            {{ form_label(registrationForm.firstName, 'First Name', {'label_attr': {'class': 'form-label-custom'}}) }}
                                            {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control form-control-custom'}}) }}
                                            <div class="form-error">
                                                {{ form_errors(registrationForm.firstName) }}
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <div class="form-group-custom">
                                            {{ form_label(registrationForm.lastName, 'Last Name', {'label_attr': {'class': 'form-label-custom'}}) }}
                                            {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-control form-control-custom'}}) }}
                                            <div class="form-error">
                                                {{ form_errors(registrationForm.lastName) }}
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group-custom">
                                    {{ form_label(registrationForm.email, 'Email Address', {'label_attr': {'class': 'form-label-custom'}}) }}
                                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control form-control-custom'}}) }}
                                    <div class="form-error">
                                        {{ form_errors(registrationForm.email) }}
                                    </div>
                                </div>

                                <div class="form-group-custom">
                                    {{ form_label(registrationForm.phone, 'Phone Number', {'label_attr': {'class': 'form-label-custom'}}) }}
                                    {{ form_widget(registrationForm.phone, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'Enter your phone number'}}) }}
                                    <div class="form-error">
                                        {{ form_errors(registrationForm.phone) }}
                                    </div>
                                </div>

                                <div class="form-group-custom">
                                    {{ form_label(registrationForm.roles, 'Account Type', {'label_attr': {'class': 'form-label-custom'}}) }}

                                    <div class="radio-group">
                                        {% for child in registrationForm.roles %}
                                            <div class="radio-option">
                                                {{ form_widget(child, {
                                                    'attr': {'class': 'radio-input'}
                                                }) }}
                                                <label for="{{ child.vars.id }}" class="radio-label {{ child.vars.value == 'ROLE_PATIENT' ? 'role-patient' : 'role-doctor' }}">
                                                    <span class="radio-icon"></span>
                                                    <i class="fas {{ child.vars.value == 'ROLE_PATIENT' ? 'fa-user-injured' : 'fa-user-md' }} role-icon"></i>
                                                    {{ child.vars.label }}
                                                </label>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    <div class="form-error">
                                        {{ form_errors(registrationForm.roles) }}
                                    </div>

                                    <!-- Role Descriptions -->
                                    <div class="role-description">
                                        <h6><i class="fas fa-user-injured me-2"></i>Patient</h6>
                                        <p>Book appointments, manage your health records, and communicate with doctors.</p>
                                    </div>
                                    <div class="role-description mt-2">
                                        <h6><i class="fas fa-user-md me-2"></i>Doctor</h6>
                                        <p>Manage your schedule, see patients, and provide medical care through our platform.</p>
                                    </div>
                                </div>

                                <!-- Patient Fields Container -->
                                <div id="patient-fields" class="dynamic-fields-container">
                                    <h6><i class="fas fa-user-injured me-2"></i>Patient Information</h6>
                                    <div class="form-group-custom">
                                        {{ form_label(registrationForm.address, 'Address', {'label_attr': {'class': 'form-label-custom'}}) }}
                                        {{ form_widget(registrationForm.address, {'attr': {'class': 'form-control form-control-custom', 'rows': '3', 'placeholder': 'Enter your complete address'}}) }}
                                        <small class="text-muted">We'll use this for appointment reminders.</small>
                                        <div class="form-error">
                                            {{ form_errors(registrationForm.address) }}
                                        </div>
                                    </div>
                                </div>

                                <!-- Doctor Fields Container -->
                                <div id="doctor-fields" class="dynamic-fields-container">
                                    <h6><i class="fas fa-user-md me-2"></i>Professional Information</h6>
                                    <div class="form-group-custom">
                                        {{ form_label(registrationForm.specialty, 'Medical Specialty', {'label_attr': {'class': 'form-label-custom'}}) }}
                                        {{ form_widget(registrationForm.specialty, {'attr': {'class': 'form-control form-control-custom', 'placeholder': 'e.g., Cardiology, Pediatrics'}}) }}
                                        <div class="form-error">
                                            {{ form_errors(registrationForm.specialty) }}
                                        </div>
                                    </div>
                                    <div class="form-group-custom">
                                        {{ form_label(registrationForm.bio, 'Professional Bio', {'label_attr': {'class': 'form-label-custom'}}) }}
                                        {{ form_widget(registrationForm.bio, {'attr': {'class': 'form-control form-control-custom', 'rows': '4', 'placeholder': 'Tell patients about your experience...'}}) }}
                                        <div class="form-error">
                                            {{ form_errors(registrationForm.bio) }}
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group-custom">
                                    {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'form-label-custom'}}) }}
                                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control form-control-custom'}}) }}
                                    <div class="form-error">
                                        {{ form_errors(registrationForm.plainPassword) }}
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-register">
                                    <i class="fas fa-user-plus me-2"></i>Create Account
                                </button>
                                {{ form_end(registrationForm) }}

                                <div class="login-link">
                                    Already have an account? <a href="{{ path('app_login') }}">Sign in here</a>
                                </div>
                            </div>

                            <!-- Benefits Sidebar - Hidden on mobile, visible on tablet+ -->
                            <div class="d-none d-lg-block col-lg-5 offset-lg-1 mt-5 mt-lg-0">
                                <div class="feature-icon-small">
                                    <i class="fas fa-heartbeat"></i>
                                </div>
                                <h4 style="color: var(--dark); margin-bottom: 1rem; font-size: 1.3rem;">Why Join MedicalApp?</h4>

                                <ul class="benefits-list">
                                    <li><i class="fas fa-check-circle"></i> Book appointments 24/7</li>
                                    <li><i class="fas fa-check-circle"></i> Access to verified healthcare professionals</li>
                                    <li><i class="fas fa-check-circle"></i> Smart appointment reminders</li>
                                    <li><i class="fas fa-check-circle"></i> Secure health records</li>
                                    <li><i class="fas fa-check-circle"></i> Easy prescription management</li>
                                    <li><i class="fas fa-check-circle"></i> Priority customer support</li>
                                </ul>

                                <div class="mt-4 p-3" style="background: var(--light); border-radius: 12px;">
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-shield-alt text-success me-3" style="font-size: 1.3rem;"></i>
                                        <div>
                                            <h6 class="mb-1" style="color: var(--dark); font-size: 0.9rem;">Secure & Private</h6>
                                            <p class="mb-0 small" style="color: var(--secondary); font-size: 0.75rem;">Your health data is encrypted</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleRadios = document.querySelectorAll('input[name^="registration_form[roles]"]');
            const patientFields = document.getElementById('patient-fields');
            const doctorFields = document.getElementById('doctor-fields');
            const roleDescriptions = document.querySelectorAll('.role-description');

            function updateRoleSpecificFields() {
                const selectedRole = document.querySelector('input[name^="registration_form[roles]"]:checked')?.value;

                patientFields.classList.remove('active');
                doctorFields.classList.remove('active');

                roleDescriptions.forEach(desc => {
                    desc.style.opacity = '0.6';
                    desc.style.borderLeftColor = '#e3ebf6';
                });

                if (selectedRole === 'ROLE_PATIENT') {
                    patientFields.classList.add('active');
                    if(roleDescriptions[0]) {
                        roleDescriptions[0].style.opacity = '1';
                        roleDescriptions[0].style.borderLeftColor = 'var(--primary)';
                    }
                } else if (selectedRole === 'ROLE_DOCTOR') {
                    doctorFields.classList.add('active');
                    if(roleDescriptions[1]) {
                        roleDescriptions[1].style.opacity = '1';
                        roleDescriptions[1].style.borderLeftColor = 'var(--primary)';
                    }
                }
            }

            roleRadios.forEach(radio => {
                radio.addEventListener('change', updateRoleSpecificFields);
            });

            updateRoleSpecificFields();

            // Password strength indicator
            const passwordInput = document.querySelector('#registration_form_plainPassword');
            if (passwordInput) {
                passwordInput.addEventListener('input', function() {
                    const password = this.value;
                    
                    let strength = 0;
                    if (password.length >= 8) strength++;
                    if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength++;
                    if (password.match(/\d/)) strength++;
                    if (password.match(/[^a-zA-Z\d]/)) strength++;

                    const strengthText = ['Very Weak', 'Weak', 'Fair', 'Strong', 'Very Strong'][strength];
                    const strengthColors = ['#dc3545', '#ffc107', '#fd7e14', '#20c997', '#198754'];
                    const strengthWidth = [25, 50, 75, 100, 100][strength];

                    let indicator = this.parentNode.querySelector('.password-strength');
                    if (!indicator) {
                        indicator = document.createElement('div');
                        indicator.className = 'password-strength mt-2';
                        this.parentNode.appendChild(indicator);
                    }
                    
                    indicator.innerHTML = `
                        <div class="progress" style="height: 4px;">
                            <div class="progress-bar" style="width: ${strengthWidth}%; background-color: ${strengthColors[strength]};"></div>
                        </div>
                        <small style="color: ${strengthColors[strength]};">${strengthText}</small>
                    `;
                });
            }
        });
    </script>
{% endblock %}
