{# templates/doctor/appointments/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}MedicalApp - My Appointments{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #2c7be5;
            --primary-light: #e3ebf8;
            --primary-dark: #1a68d1;
            --secondary: #6e84a3;
            --success: #00d97e;
            --success-light: #e6f9f0;
            --warning: #f6c343;
            --warning-light: #fef8e6;
            --danger: #e63757;
            --danger-light: #fce9ec;
            --info: #39afd1;
            --info-light: #eaf5f9;
            --light: #f9fbfd;
            --dark: #12263f;
            --gray-100: #f8f9fa;
            --gray-200: #e9ecef;
            --gray-300: #dee2e6;
            --gray-400: #ced4da;
            --gray-500: #adb5bd;
            --gray-600: #6c757d;
            --gray-700: #495057;
            --prescription: #9b59b6;
            --prescription-light: #f3e8f7;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --body-bg: #f5f7fb;
            --gradient-primary: linear-gradient(135deg, #2c7be5 0%, #1a68d1 100%);
            --shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            --shadow-lg: 0 1rem 3rem rgba(0, 0, 0, 0.175);
            --border-radius: 0.75rem;
            --border-radius-sm: 0.5rem;
            --transition: all 0.3s ease;
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .dashboard-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--gray-200);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .doctor-avatar {
            width: 50px;
            height: 50px;
            background: var(--gradient-primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.25rem;
            font-weight: 600;
        }

        .doctor-info h6 {
            margin-bottom: 0.25rem;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .doctor-info small {
            color: var(--gray-600);
            font-size: 0.8rem;
        }

        .sidebar-nav {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        .nav-section {
            margin-bottom: 2rem;
        }

        .nav-section-title {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--gray-600);
            letter-spacing: 0.5px;
            margin-bottom: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 0.7rem 1rem;
            border-radius: var(--border-radius-sm);
            color: var(--gray-700);
            text-decoration: none;
            margin-bottom: 0.5rem;
            transition: var(--transition);
            font-weight: 500;
            font-size: 0.9rem;
        }

        .nav-item:hover {
            background: var(--primary-light);
            color: var(--primary);
            transform: translateX(5px);
        }

        .nav-item.active {
            background: var(--gradient-primary);
            color: white;
            box-shadow: 0 4px 12px rgba(44, 123, 229, 0.3);
        }

        .nav-icon {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            background: var(--gray-100);
            color: var(--gray-600);
            transition: var(--transition);
        }

        .nav-item:hover .nav-icon {
            background: white;
        }

        .nav-item.active .nav-icon {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--gray-200);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            padding: 0.7rem 1rem;
            border-radius: var(--border-radius-sm);
            color: var(--danger);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: var(--transition);
        }

        .logout-btn:hover {
            background: var(--danger-light);
        }

        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 1.5rem;
            max-width: calc(100% - 280px);
        }

        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--gray-200);
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-left h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.25rem;
        }

        .header-left p {
            color: var(--gray-600);
            margin: 0;
            font-size: 0.85rem;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .date-badge {
            background: var(--primary-light);
            color: var(--primary);
            padding: 0.4rem 0.8rem;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.8rem;
        }

        .dashboard-section {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .section-header h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--dark);
            margin: 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: var(--border-radius-sm);
            padding: 0.8rem;
            border: 1px solid var(--gray-200);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }

        .stat-card.total::before { background: var(--primary); }
        .stat-card.pending::before { background: var(--warning); }
        .stat-card.confirmed::before { background: var(--success); }
        .stat-card.cancelled::before { background: var(--danger); }

        .stat-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-icon {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .stat-card.total .stat-icon { background: var(--primary-light); color: var(--primary); }
        .stat-card.pending .stat-icon { background: var(--warning-light); color: var(--warning); }
        .stat-card.confirmed .stat-icon { background: var(--success-light); color: var(--success); }
        .stat-card.cancelled .stat-icon { background: var(--danger-light); color: var(--danger); }

        .stat-numbers h3 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 0.2rem;
            color: var(--dark);
        }

        .stat-numbers p {
            color: var(--gray-600);
            font-size: 0.7rem;
            margin: 0;
        }

        .filter-card {
            background: var(--gray-100);
            border-radius: var(--border-radius-sm);
            padding: 0.75rem;
            margin-bottom: 1rem;
        }

        .filter-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.75rem;
            align-items: end;
        }

        .form-group {
            margin-bottom: 0;
        }

        .form-label {
            font-size: 0.7rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: var(--gray-700);
        }

        .form-control, .form-select {
            border-radius: var(--border-radius-sm);
            border: 1px solid var(--gray-300);
            padding: 0.4rem 0.6rem;
            font-size: 0.8rem;
            width: 100%;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 0.2rem rgba(44,123,229,0.1);
        }

        .input-group {
            display: flex;
            gap: 0.5rem;
        }

        .btn {
            padding: 0.4rem 0.8rem;
            border-radius: var(--border-radius-sm);
            font-weight: 500;
            font-size: 0.8rem;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        .btn-outline-primary {
            background: transparent;
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .btn-outline-primary:hover {
            background: var(--primary);
            color: white;
        }

        .btn-sm {
            padding: 0.2rem 0.5rem;
            font-size: 0.7rem;
        }

        .appointment-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .appointment-item {
            display: flex;
            align-items: center;
            padding: 0.8rem;
            background: var(--gray-100);
            border-radius: var(--border-radius-sm);
            transition: var(--transition);
            border-left: 4px solid transparent;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .appointment-item:hover {
            background: var(--gray-200);
            transform: translateX(5px);
        }

        .appointment-item.pending { border-left-color: var(--warning); }
        .appointment-item.confirmed { border-left-color: var(--success); }
        .appointment-item.cancelled { border-left-color: var(--danger); }

        .appointment-time {
            min-width: 90px;
            text-align: center;
            padding: 0.4rem;
            background: white;
            border-radius: 8px;
        }

        .appointment-time .time {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--dark);
            display: block;
        }

        .appointment-time .date {
            font-size: 0.7rem;
            color: var(--gray-600);
        }

        .patient-info {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            min-width: 140px;
        }

        .patient-avatar {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            background: var(--gradient-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .patient-details h6 {
            font-weight: 600;
            margin-bottom: 0.2rem;
            color: var(--dark);
            font-size: 0.85rem;
        }

        .patient-details p {
            color: var(--gray-600);
            font-size: 0.7rem;
            margin: 0;
        }

        .appointment-status {
            padding: 0.2rem 0.6rem;
            border-radius: 50px;
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-pending { background: var(--warning-light); color: var(--warning); }
        .status-confirmed { background: var(--success-light); color: var(--success); }
        .status-cancelled { background: var(--danger-light); color: var(--danger); }

        .appointment-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .btn-action {
            padding: 0.4rem 0.7rem;
            border-radius: 8px;
            font-size: 0.7rem;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            border: none;
            transition: var(--transition);
        }

        .btn-confirm {
            background: var(--success);
            color: white;
        }
        .btn-confirm:hover { background: #00b86c; transform: translateY(-2px); }

        .btn-prescribe {
            background: var(--prescription);
            color: white;
        }
        .btn-prescribe:hover { background: var(--prescription-dark); transform: translateY(-2px); }

        .btn-cancel {
            background: var(--danger-light);
            color: var(--danger);
        }
        .btn-cancel:hover { background: var(--danger); color: white; transform: translateY(-2px); }

        .btn-disabled {
            background: var(--gray-300);
            color: var(--gray-600);
            cursor: not-allowed;
        }

        .prescribed-badge {
            background: var(--success-light);
            color: var(--success);
            padding: 0.4rem 0.7rem;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--gray-600);
        }

        .empty-state i {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
            color: var(--gray-400);
        }

        .empty-state h5 {
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .alert {
            border-radius: var(--border-radius-sm);
            padding: 0.75rem;
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        .toast-notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 0.75rem 1rem;
            border-radius: var(--border-radius-sm);
            background: white;
            box-shadow: var(--shadow-lg);
            z-index: 9999;
            display: flex;
            align-items: center;
            animation: slideIn 0.3s ease;
            border-left: 4px solid;
            font-size: 0.85rem;
        }

        .toast-success { border-left-color: var(--success); color: var(--success); }
        .toast-warning { border-left-color: var(--warning); color: var(--warning); }
        .toast-danger { border-left-color: var(--danger); color: var(--danger); }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @media (max-width: 992px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                margin-bottom: 1rem;
            }
            .main-content {
                margin-left: 0;
                max-width: 100%;
                padding: 1rem;
            }
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .top-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .header-right {
                width: 100%;
                justify-content: space-between;
            }
            .filter-form {
                grid-template-columns: 1fr;
            }
            .appointment-item {
                flex-direction: column;
                align-items: stretch;
            }
            .appointment-time {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .appointment-actions {
                width: 100%;
                justify-content: flex-end;
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .header-left h1 {
                font-size: 1.2rem;
            }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}
    <div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="doctor-avatar">
                    {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                </div>
                <div class="doctor-info">
                    <h6>Dr. {{ app.user.firstName }} {{ app.user.lastName }}</h6>
                    <small>{{ app.user.doctor.specialty ?? 'Medical Professional' }}</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a href="{{ path('doctor_dashboard') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-home"></i></div>
                        Dashboard
                    </a>
                    <a href="{{ path('doctor_appointments') }}" class="nav-item active">
                        <div class="nav-icon"><i class="fas fa-calendar-alt"></i></div>
                        Appointments
                    </a>
                    <a href="{{ path('doctor_prescriptions') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-file-prescription"></i></div>
                        Prescriptions
                    </a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">Schedule</div>
                    <a href="{{ path('doctor_availability') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-clock"></i></div>
                        Availability
                    </a>
                    <a href="{{ path('doctor_patients') }}" class="nav-item">
                        <div class="nav-icon"><i class="fas fa-user-friends"></i></div>
                        My Patients
                    </a>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="{{ path('app_logout') }}" class="logout-btn">
                    <i class="fas fa-sign-out-alt me-2"></i> Logout
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-header">
                <div class="header-left">
                    <h1>My Appointments</h1>
                    <p>Manage and view all your scheduled appointments</p>
                </div>
                <div class="header-right">
                    <div class="date-badge">
                        <i class="fas fa-calendar-day me-2"></i>{{ "now"|date("M j, Y") }}
                    </div>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="stats-grid">
                <div class="stat-card total">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                            <div class="stat-numbers">
                                <h3>{{ stats.total|default(0) }}</h3>
                                <p>Total</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="stat-card pending">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon"><i class="fas fa-clock"></i></div>
                            <div class="stat-numbers">
                                <h3>{{ stats.pending|default(0) }}</h3>
                                <p>Pending</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="stat-card confirmed">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                            <div class="stat-numbers">
                                <h3>{{ stats.confirmed|default(0) }}</h3>
                                <p>Confirmed</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="stat-card cancelled">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon"><i class="fas fa-ban"></i></div>
                            <div class="stat-numbers">
                                <h3>{{ stats.cancelled|default(0) }}</h3>
                                <p>Cancelled</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12 col-lg-8">
                    <div class="dashboard-section">
                        <div class="section-header">
                            <h3><i class="fas fa-calendar-alt me-2 text-primary"></i>All Appointments</h3>
                            <button class="btn btn-outline-primary btn-sm" onclick="resetFilters()">
                                <i class="fas fa-redo me-1"></i> Reset
                            </button>
                        </div>

                        <div class="filter-card">
                            <form method="get" class="filter-form" id="filterForm">
                                <div class="form-group">
                                    <label class="form-label">Status</label>
                                    <select name="status" class="form-select" onchange="this.form.submit()">
                                        <option value="all" {{ currentFilters.status == 'all' or not currentFilters.status ? 'selected' : '' }}>All</option>
                                        <option value="Pending" {{ currentFilters.status == 'Pending' ? 'selected' : '' }}>Pending</option>
                                        <option value="Confirmed" {{ currentFilters.status == 'Confirmed' ? 'selected' : '' }}>Confirmed</option>
                                        <option value="Cancelled" {{ currentFilters.status == 'Cancelled' ? 'selected' : '' }}>Cancelled</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Date</label>
                                    <input type="date" name="date" class="form-control" value="{{ currentFilters.date }}" onchange="this.form.submit()">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Search</label>
                                    <div class="input-group">
                                        <input type="text" name="search" class="form-control" placeholder="Patient name..." value="{{ currentFilters.search }}">
                                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        {% if appointments|length > 0 %}
                            <div class="appointment-list">
                                {% for appointment in appointments %}
                                    <div class="appointment-item {{ appointment.status|lower }}">
                                        <div class="appointment-time">
                                            <span class="time">{{ appointment.startDateTime|date('h:i A') }}</span>
                                            <span class="date">{{ appointment.startDateTime|date('M j, Y') }}</span>
                                        </div>
                                        <div class="patient-info">
                                            <div class="patient-avatar">
                                                {{ appointment.patient.client.firstName|first|upper }}{{ appointment.patient.client.lastName|first|upper }}
                                            </div>
                                            <div class="patient-details">
                                                <h6>{{ appointment.patient.client.firstName }} {{ appointment.patient.client.lastName }}</h6>
                                                <p><i class="fas fa-phone me-1"></i>{{ appointment.patient.phone ?? 'No phone' }}</p>
                                            </div>
                                        </div>
                                        <span class="appointment-status status-{{ appointment.status|lower }}">{{ appointment.status }}</span>
                                        <div class="appointment-actions">
                                            {% if appointment.status == 'Pending' %}
                                                <button class="btn-action btn-confirm" onclick="confirmAppointment({{ appointment.id }})"><i class="fas fa-check"></i> Confirm</button>
                                                <button class="btn-action btn-cancel" onclick="cancelAppointment({{ appointment.id }})"><i class="fas fa-times"></i> Cancel</button>
                                            {% elseif appointment.status == 'Confirmed' %}
                                                <a href="{{ path('doctor_prescription_upload', {'id': appointment.id}) }}" class="btn-action btn-prescribe"><i class="fas fa-file-prescription"></i> Prescribe</a>
                                            {% elseif appointment.status == 'Cancelled' %}
                                                <span class="btn-disabled">Cancelled</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="empty-state">
                                <i class="fas fa-calendar-times"></i>
                                <h5>No appointments found</h5>
                                <button class="btn btn-primary mt-2" onclick="resetFilters()">Reset Filters</button>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="dashboard-section">
                        <div class="section-header">
                            <h3><i class="fas fa-calendar-check me-2 text-success"></i>Upcoming</h3>
                        </div>
                        {% if upcomingAppointments|length > 0 %}
                            <div class="appointment-list">
                                {% for appointment in upcomingAppointments %}
                                    <div class="appointment-item confirmed">
                                        <div class="appointment-time">
                                            <span class="time">{{ appointment.startDateTime|date('h:i A') }}</span>
                                            <span class="date">{{ appointment.startDateTime|date('M j') }}</span>
                                        </div>
                                        <div class="patient-info">
                                            <div class="patient-avatar">
                                                {{ appointment.patient.client.firstName|first|upper }}{{ appointment.patient.client.lastName|first|upper }}
                                            </div>
                                            <div class="patient-details">
                                                <h6>{{ appointment.patient.client.firstName }}</h6>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="empty-state">
                                <i class="fas fa-calendar-plus"></i>
                                <h5>No upcoming</h5>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function confirmAppointment(id) {
            if (confirm('Confirm this appointment?')) {
                fetch('{{ path('doctor_appointment_confirm', {'id': 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', id), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
                }).then(r => r.json()).then(data => {
                    if (data.success) { showToast('Confirmed!', 'success'); setTimeout(() => location.reload(), 1000); }
                    else showToast('Error: ' + data.message, 'danger');
                });
            }
        }

        function cancelAppointment(id) {
            if (confirm('Cancel this appointment?')) {
                fetch('{{ path('doctor_appointment_cancel', {'id': 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', id), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
                }).then(r => r.json()).then(data => {
                    if (data.success) { showToast('Cancelled!', 'warning'); setTimeout(() => location.reload(), 1000); }
                    else showToast('Error: ' + data.message, 'danger');
                });
            }
        }

        function resetFilters() { window.location.href = '{{ path('doctor_appointments') }}'; }

        function showToast(msg, type) {
            document.querySelectorAll('.toast-notification').forEach(t => t.remove());
            const toast = document.createElement('div');
            toast.className = `toast-notification toast-${type}`;
            toast.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>${msg}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
{% endblock %}