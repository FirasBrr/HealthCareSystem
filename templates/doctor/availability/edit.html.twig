{% extends 'base.html.twig' %}

{% block title %}MedicalApp - Edit Availability{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .availability-section {
            background: #f5f7fb;
            min-height: 100vh;
            padding: 20px 0;
        }

        .form-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }

        .btn-primary {
            background: #2c7be5;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background: #1a68d1;
            transform: translateY(-2px);
        }

        .btn-danger {
            background: #e63757;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-danger:hover {
            background: #d42a4a;
            transform: translateY(-2px);
        }

        .btn-light {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-light:hover {
            background: #e9ecef;
            text-decoration: none;
        }

        .form-label {
            font-weight: 600;
            color: #12263f;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .form-control {
            border: 1px solid #e6e6e6;
            border-radius: 8px;
            padding: 8px 12px;
            transition: all 0.3s ease;
            width: 100%;
            font-size: 0.9rem;
        }

        .form-control:focus {
            border-color: #2c7be5;
            box-shadow: 0 0 0 0.2rem rgba(44, 123, 229, 0.25);
            outline: none;
        }

        .form-check-input {
            width: 40px;
            height: 20px;
            margin-top: 0;
        }

        .form-check-input:checked {
            background-color: #2c7be5;
            border-color: #2c7be5;
        }

        .form-check-label {
            margin-left: 10px;
            font-weight: 500;
        }

        .current-slot-info {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            border-left: 4px solid #2c7be5;
        }

        .current-slot-info h6 {
            font-size: 0.9rem;
            margin-bottom: 12px;
        }

        .info-text small {
            font-size: 0.7rem;
        }

        .badge {
            padding: 0.25rem 0.5rem;
            font-size: 0.7rem;
            border-radius: 50px;
        }

        .bg-primary { background: #2c7be5; color: white; }
        .bg-secondary { background: #6c757d; color: white; }
        .bg-success { background: #00d97e; color: white; }
        .bg-danger { background: #e63757; color: white; }

        .text-muted {
            color: #6c757d;
            font-size: 0.75rem;
        }

        .form-text {
            font-size: 0.7rem;
            margin-top: 4px;
        }

        .gap-2 {
            gap: 0.5rem;
        }

        hr {
            margin: 1.5rem 0;
        }

        /* Responsive */
        @media (min-width: 768px) {
            .availability-section {
                padding: 30px 0;
            }
            .form-card {
                padding: 30px;
            }
            .current-slot-info {
                padding: 20px;
            }
        }

        @media (max-width: 768px) {
            .form-card {
                padding: 15px;
            }
            .btn-primary, .btn-danger, .btn-light {
                padding: 8px 16px;
                font-size: 0.85rem;
            }
            .current-slot-info .row {
                flex-direction: column;
                gap: 10px;
            }
            .d-flex.gap-2 {
                flex-direction: column;
            }
            .d-flex.gap-2 .btn {
                width: 100%;
                justify-content: center;
            }
            .btn-light {
                margin-bottom: 0;
            }
        }

        @media (max-width: 480px) {
            .form-card {
                padding: 12px;
            }
            h1.h3 {
                font-size: 1.2rem;
            }
            .current-slot-info h6 {
                font-size: 0.85rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="availability-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8">
                    <!-- Current Slot Information -->
                    <div class="current-slot-info">
                        <h6><i class="fas fa-info-circle text-primary me-2"></i>Editing Availability Slot</h6>
                        <div class="row">
                            <div class="col-12 col-md-6 mb-2 mb-md-0">
                                <small class="text-muted">Type:</small>
                                <div>
                                    {% if availability.isRecurring %}
                                        <span class="badge bg-primary">Recurring Weekly</span>
                                    {% else %}
                                        <span class="badge bg-secondary">One-time</span>
                                    {% endif %}

                                    {% if availability.isAvailable %}
                                        <span class="badge bg-success ms-2">Available</span>
                                    {% else %}
                                        <span class="badge bg-danger ms-2">Blocked</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <small class="text-muted">Schedule:</small>
                                <div>
                                    {% if availability.isRecurring %}
                                        {{ availability.dayOfWeek }}: {{ availability.startTime|date('h:i A') }} - {{ availability.endTime|date('h:i A') }}
                                    {% else %}
                                        {{ availability.date|date('M j, Y') }}: {{ availability.startTime|date('h:i A') }} - {{ availability.endTime|date('h:i A') }}
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-card">
                        <div class="d-flex align-items-center mb-4">
                            <a href="{{ path('doctor_availability') }}" class="btn btn-light me-3">
                                <i class="fas fa-arrow-left"></i> Back
                            </a>
                            <h1 class="h3 mb-0">Edit Availability</h1>
                        </div>

                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-12 col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.dayOfWeek, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.dayOfWeek, {'attr': {'class': 'form-control'}}) }}
                                    <small class="form-text text-muted">For recurring weekly availability</small>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.date, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                                    <small class="form-text text-muted">For one-time availability</small>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.startTime, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.startTime, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.endTime, null, {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.endTime, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-6">
                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        {{ form_widget(form.recurring, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.recurring, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    <small class="form-text text-muted">Repeat weekly on selected day</small>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="mb-3">
                                    <div class="form-check form-switch">
                                        {{ form_widget(form.isAvailable, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.isAvailable, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    <small class="form-text text-muted">Toggle off to block this time</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Update Availability
                            </button>
                            <a href="{{ path('doctor_availability') }}" class="btn btn-light">Cancel</a>
                        </div>
                        {{ form_end(form) }}

                        <hr class="my-4">

                        <!-- Delete Form -->
                        <form method="post" action="{{ path('doctor_availability_delete', {'id': availability.id}) }}" onsubmit="return confirm('Are you sure you want to delete this availability slot? This action cannot be undone.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ availability.id) }}">
                            <button class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Delete Availability Slot
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}